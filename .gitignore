# -------------------------------------------------------------------------
# SECRETS & CREDENTIALS — NEVER COMMIT
# -------------------------------------------------------------------------
# Environment files
.env
.env.*
!.env.example
!.env.sample
!.env.template

# Service account / cloud credentials
*.pem
*.key
*.p12
*.pfx
*-key.json
service-account*.json
gcp-credentials*.json
aws-credentials*
credentials.json
secrets.yaml
secrets.yml
*-secret.yaml
*-secret.yml

# OAuth / OIDC client secrets
client_secret*.json
oauth*.json

# JWT signing keys (must only live in Secret Manager)
jwt-private*.pem
jwt-public*.pem
signing-key*

# SSH keys
id_rsa
id_dsa
id_ed25519
known_hosts


