# -------------------------------------------------------------------------
# INFRASTRUCTURE — TERRAFORM  (infra/)
# -------------------------------------------------------------------------
# Local state files (never commit; use remote state)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash logs
crash.log
crash.*.log

# Variable files (often contain secrets)
*.tfvars
*.tfvars.json
!example.tfvars
!*.tfvars.example

# Terraform working directories
.terraform/
.terraform.lock.hcl.bak

# CLI config
.terraformrc
terraform.rc

# Plan output
*.tfplan
*.tfplan.*


# -------------------------------------------------------------------------
# ANSIBLE  (ansible/)
# -------------------------------------------------------------------------
